{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "baseUrl": ".",
    "paths": { "#/*": ["src/*"] },
    "esModuleInterop": true,
    "skipLibCheck": true,
    "typeRoots": [
    "./node_modules/@types",
    "./src/types"
  ]

  }
}