{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "baseUrl": ".",
    "paths": { "#/*": ["src/*"] },
    "esModuleInterop": true,
    "skipLibCheck": true,
    "typeRoots": [
    "./node_modules/@types",
    "./src/types"
  ]
},
  "include": [
    "src/**/*",              
    "src/types/**/*.d.ts"    
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
}
